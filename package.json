{
  "name": "lattice-app",
  "version": "0.1.0",
  "description": "Lattice — AI-powered materials science desktop app",
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "electron:dev:wsl": "LATTICE_DISABLE_GPU=1 vite --mode electron",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "smoke:agent-tools": "node --experimental-strip-types src/__smoke__/agent-tool-audit-smoke.ts",
    "check:data": "node scripts/check-bundled-data.mjs",
    "setup": "bash scripts/download-data.sh"
  },
  "keywords": [
    "materials-science",
    "spectroscopy",
    "electron"
  ],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/dockerode": "^4.0.1",
    "3dmol": "^2.5.4",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "codemirror-lang-latex": "^0.2.0",
    "dockerode": "^4.0.10",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "jszip": "^3.10.1",
    "lib0": "^0.2.117",
    "lucide-react": "^0.487.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.169.0",
    "webdav": "^5.9.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.21",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.4"
  }
}
