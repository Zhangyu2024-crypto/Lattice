node_modules/
dist/
dist-electron/
release/
*.tsbuildinfo
.vite/
.cache/

# SQLite WAL/SHM sidecars. Transient — SQLite creates them next to a DB
# opened in WAL mode. Our bundled DBs open read-only (mode=ro&immutable=1)
# so these shouldn't appear, but catch them anyway in case someone opens
# a local copy for ad-hoc write-mode refreshes.
*.db-wal
*.db-shm
*.db-journal

# Test artifacts (Vitest)
coverage/

# Python worker generated bytecode
**/__pycache__/*
*.pyc

# Large binary assets (use Git LFS or download separately)
worker/data/mp_xrd_database.db
resources/conda-env/
public/busytex/*.data
public/busytex/*.wasm
*.zip

# AI assistant / tool process files
.claude/
.codex
.codex/
CLAUDE.md
AGENTS.md

# Session logs and unrelated documents
*.zip:Zone.Identifier
*:Zone.Identifier
20*-*-*-*.txt
china-europe-*.pdf

# Editor/IDE
.idea/
.vscode/
.DS_Store

# Experimental / scratch data — keep test data in fixtures, not repo root
/*.csv
/*.dat
/*.xy
/*.raw

# Internal design notes
/doc/
/docs/
